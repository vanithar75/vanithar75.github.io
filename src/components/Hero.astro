---
import { site, hero } from '../data/site';
---

<section class="hero section" aria-labelledby="hero-heading">
  <div class="container hero-grid">
    <div class="hero-content">
      <p class="eyebrow">Passionate Technologist · APAC</p>
      <h1 id="hero-heading">{hero.headline}</h1>
      {hero.summaries.map((paragraph) => (
        <p class="summary">{paragraph}</p>
      ))}
      <div class="hero-actions">
        <a class="btn btn-primary" href="#contact">Get in touch</a>
        <a class="btn btn-secondary" href={site.linkedin} rel="noopener noreferrer" target="_blank">
          LinkedIn profile
        </a>
      </div>
    </div>

    <aside class="hero-aside" aria-label="Profile summary">
      <div class="portrait">
        <img
          src="/images/profile.png"
          alt="Vanitha Ramaswami"
          width="320"
          height="320"
          loading="eager"
          decoding="async"
        />
      </div>
      <dl class="quick-facts">
        <div>
          <dt>Focus</dt>
          <dd>Edge-to-cloud · Enterprise AI · Governance</dd>
        </div>
        <div>
          <dt>Location</dt>
          <dd>{site.location}</dd>
        </div>
        <div>
          <dt>Trajectory</dt>
          <dd>Principal Architect</dd>
        </div>
      </dl>
    </aside>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--space-3xl) + var(--space-md));
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, var(--color-accent-subtle), transparent),
      var(--color-bg);
  }

  .hero-grid {
    display: grid;
    gap: var(--space-2xl);
    align-items: start;
  }

  @media (min-width: 56rem) {
    .hero-grid {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .eyebrow {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .summary {
    font-size: 1.0625rem;
    color: var(--color-text-muted);
    max-width: 38rem;
    margin-bottom: var(--space-md);
  }

  .summary:last-of-type {
    margin-bottom: var(--space-xl);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .hero-aside {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-md);
  }

  .portrait {
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    margin-bottom: var(--space-lg);
    border: 3px solid var(--color-border);
    box-shadow: var(--shadow-md);
  }

  .portrait img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .quick-facts {
    margin: 0;
    display: grid;
    gap: var(--space-md);
  }

  .quick-facts div {
    display: grid;
    gap: 0.15rem;
  }

  .quick-facts dt {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .quick-facts dd {
    margin: 0;
    font-size: 0.9375rem;
    color: var(--color-text);
  }
</style>
