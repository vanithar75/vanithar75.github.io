---
import { site } from '../data/site';
---

<section id="contact" class="section section-alt" aria-labelledby="contact-heading">
  <div class="container contact-grid">
    <div>
      <header class="section-header">
        <span class="section-label">Contact</span>
        <h2 id="contact-heading">Let's connect</h2>
        <p class="section-intro">
          Open to conversations on enterprise AI strategy, governance assessments, edge-to-cloud architecture, and technology leadership.
        </p>
      </header>
    </div>

    <div class="contact-card card">
      <ul class="contact-links">
        <li>
          <span class="label">LinkedIn</span>
          <a href={site.linkedin} rel="noopener noreferrer" target="_blank">
            linkedin.com/in/vanithar75
          </a>
        </li>
        <li>
          <span class="label">GitHub</span>
          <a href={site.github} rel="noopener noreferrer" target="_blank">
            github.com/vanithar75
          </a>
        </li>
        <li>
          <span class="label">Location</span>
          <span>{site.location}</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 48rem) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-lg);
  }

  .contact-links li {
    display: grid;
    gap: 0.25rem;
  }

  .label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-text-subtle);
  }

  .contact-links a {
    font-weight: 500;
    text-decoration: none;
  }
</style>
